# --- DreamBees Root Environment Variables ---
# Used by Electron main process and Vite renderer

# Hugging Face Token (Optional / AI models)
VITE_HUGGING_FACE_TOKEN=hf_your_token_here

# Backblaze B2 (Cloud Storage for Generated Images)
VITE_B2_ENDPOINT=https://s3.your-region.backblazeb2.com
VITE_B2_REGION=your-region
VITE_B2_BUCKET=your-bucket-name
VITE_B2_KEY_ID=your-backblaze-key-id
VITE_B2_APP_KEY=your-backblaze-app-key
VITE_B2_PUBLIC_URL=https://cdn.yourdomain.com

# OpenRouter API (Fallback / Alternative Prompt Engineering)
VITE_OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Firebase Client Configuration (Web/App Initialization)
VITE_FIREBASE_API_KEY=AIzaSyYourApiKey
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef123456
VITE_FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com/

# Cloudflare Turnstile (Bot & Abuse Prevention)
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAYourSiteKey

# Cloudflare Workers / AI (Internal Scripts)
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Optional Proxy settings for local developer routing
# VITE_DREAMTRAIL_API_PROXY_TARGET=http://localhost:5001
# VITE_DREAMTRAIL_API_PROXY_PATH=/api
