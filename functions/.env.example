# --- DreamBees Firebase Functions Environment Variables ---
# Consumed by Cloud Functions during runtime / emulators

# Backblaze B2 Storage configuration (S3 SDK)
B2_KEY_ID=your_backblaze_key_id
B2_APP_KEY=your_backblaze_app_key
B2_BUCKET=your_bucket_name
B2_ENDPOINT=https://s3.your-region.backblazeb2.com
B2_REGION=your-region
B2_PUBLIC_URL=https://cdn.yourdomain.com

# Stripe Keys (Subscriptions & Payments)
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# OpenRouter API (Primary LLM model for DreamTrail prompt expansion)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
OPENROUTER_DREAMTRAIL_MODEL=google/gemini-2.5-flash

# Cloudflare (Dynamic DNS, CDN, and Turnstile verification)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Google Cloud / Google AI Platform Key
GOOGLE_API_KEY=AIzaSyYourGoogleApiKey

# Firebase Configuration
# Note: RTDB_URL is used by functions to access Realtime Database.
RTDB_URL=https://your-project-id-default-rtdb.firebaseio.com/
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com/
VITE_FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com/

# Bot Server Upstream URL (For dispatching workers/tasks)
BOT_UPSTREAM_URL=http://your-bot-server-ip:8080

# Diagnostic & Admin Access Key (Required for /diagnostic endpoint)
ADMIN_DIAGNOSTIC_KEY=your_admin_diagnostic_security_key

# Admin Generation API Key (Required for adminGeneration cloud function)
# No Firebase user login required — this key is the only gate.
ADMIN_GENERATION_KEY=your_admin_generation_security_key
